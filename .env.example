# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# SMTP Email Configuration (Future / Notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=secret-password
SMTP_FROM="Ravenshaw Moments <noreply@ravenshawmoments.com>"

# PayU Payment Gateway Configuration
PAYU_ENV=test
PAYU_MERCHANT_KEY=your-merchant-key-here
PAYU_MERCHANT_SALT=your-merchant-salt-here

# Cloudflare R2 Storage (Media Uploads)
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=your-r2-bucket
